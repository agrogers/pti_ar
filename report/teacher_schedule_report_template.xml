<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Portrait A4 Paper Format -->
    <record id="paperformat_teacher_schedule" model="report.paperformat">
        <field name="name">Teacher Schedule (Portrait A4)</field>
        <field name="default" eval="False"/>
        <field name="format">A4</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">10</field>
        <field name="margin_bottom">10</field>
        <field name="margin_left">10</field>
        <field name="margin_right">10</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">0</field>
        <field name="dpi">90</field>
    </record>

    <!-- Report Action (appears in Print menu of teacher summary list) -->
    <record id="action_report_teacher_schedule" model="ir.actions.report">
        <field name="name">Teacher Interview Schedule</field>
        <field name="model">pti.teacher.meeting.summary</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">pti_ar.teacher_schedule_report</field>
        <field name="report_file">pti_ar.teacher_schedule_report</field>
        <field name="binding_model_id" ref="model_pti_teacher_meeting_summary"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="pti_ar.paperformat_teacher_schedule"/>
    </record>

    <!-- QWeb Report Template -->
    <template id="teacher_schedule_report">
        <t t-call="web.html_container">
            <t t-foreach="report_data" t-as="data">
                <div class="article" t-attf-style="page-break-after: {{ 'always' if not data_last else 'auto' }};">
                    <style>
                        .pti-header {
                            display: flex;
                            align-items: center;
                            margin-bottom: 16px;
                            padding-bottom: 12px;
                            border-bottom: 2px solid #333;
                        }
                        .pti-photo {
                            width: 72px;
                            height: 72px;
                            border-radius: 50%;
                            object-fit: cover;
                            margin-right: 16px;
                            border: 2px solid #ccc;
                        }
                        .pti-initials-lg {
                            width: 72px;
                            height: 72px;
                            border-radius: 50%;
                            background-color: #875a7b;
                            color: #fff;
                            display: flex;
                            align-items: center;
                            justify-content: center;
                            font-size: 28px;
                            font-weight: bold;
                            margin-right: 16px;
                            flex-shrink: 0;
                        }
                        .pti-teacher-name {
                            font-size: 22px;
                            font-weight: bold;
                            margin: 0;
                        }
                        .pti-cycle-name {
                            font-size: 13px;
                            color: #666;
                            margin: 4px 0 0 0;
                        }
                        .pti-table {
                            width: 100%;
                            border-collapse: collapse;
                            font-size: 12px;
                        }
                        .pti-table th {
                            background-color: #f5f5f5;
                            border: 1px solid #ddd;
                            padding: 6px 8px;
                            text-align: left;
                            font-weight: bold;
                        }
                        .pti-table td {
                            border: 1px solid #ddd;
                            padding: 5px 8px;
                            vertical-align: top;
                        }
                        .pti-date-cell {
                            font-weight: bold;
                            white-space: nowrap;
                        }
                        .pti-time-cell {
                            white-space: nowrap;
                        }
                        .pti-student {
                            display: flex;
                            align-items: center;
                            margin-bottom: 3px;
                        }
                        .pti-student:last-child {
                            margin-bottom: 0;
                        }
                        .pti-student-photo {
                            width: 24px;
                            height: 24px;
                            border-radius: 50%;
                            object-fit: cover;
                            margin-right: 6px;
                            flex-shrink: 0;
                        }
                        .pti-initials-sm {
                            width: 24px;
                            height: 24px;
                            border-radius: 50%;
                            background-color: #00a09d;
                            color: #fff;
                            display: inline-flex;
                            align-items: center;
                            justify-content: center;
                            font-size: 10px;
                            font-weight: bold;
                            margin-right: 6px;
                            flex-shrink: 0;
                        }
                        .pti-notes {
                            font-size: 11px;
                            color: #444;
                        }
                        .pti-observer-tag {
                            font-size: 10px;
                            color: #888;
                            font-style: italic;
                        }
                    </style>

                    <!-- Teacher Header with photo/initials -->
                    <div class="pti-header">
                        <t t-if="data['teacher'].image_128">
                            <img class="pti-photo"
                                 t-att-src="image_data_uri(data['teacher'].image_128)"/>
                        </t>
                        <t t-else="">
                            <div class="pti-initials-lg">
                                <t t-esc="data['teacher_initials']"/>
                            </div>
                        </t>
                        <div>
                            <p class="pti-teacher-name" t-esc="data['teacher'].name"/>
                            <p class="pti-cycle-name" t-esc="data['cycle'].display_name"/>
                        </div>
                    </div>

                    <!-- Schedule Table -->
                    <table class="pti-table">
                        <thead>
                            <tr>
                                <th style="width: 15%;">Date &amp; Time</th>
                                <th style="width: 25%;">Student(s)</th>
                                <th style="width: 20%;">Parents &amp; Observers</th>
                                <th>Notes</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="data['slots']" t-as="slot">
                                <tr>
                                    <!-- Date & Time -->
                                    <td>
                                        <t t-if="slot['date_display']">
                                            <div class="pti-date-cell"
                                                 t-esc="slot['date_display']"/>
                                        </t>
                                        <div class="pti-time-cell"
                                             t-esc="slot['time_display']"/>
                                    </td>

                                    <!-- Connected Students -->
                                    <td>
                                        <t t-foreach="slot['students']" t-as="student">
                                            <div class="pti-student">
                                                <t t-if="student['partner'].image_128">
                                                    <img class="pti-student-photo"
                                                         t-att-src="image_data_uri(student['partner'].image_128)"/>
                                                </t>
                                                <t t-else="">
                                                    <span class="pti-initials-sm">
                                                        <t t-esc="student['initials']"/>
                                                    </span>
                                                </t>
                                                <span t-esc="student['partner'].name"/>
                                            </div>
                                        </t>
                                    </td>

                                    <!-- Parents & Observers -->
                                    <td>
                                        <t t-foreach="slot['parents_observers']" t-as="po">
                                            <div>
                                                <span t-esc="po['name']"/>
                                                <t t-if="po['role']">
                                                    <span class="pti-observer-tag">
                                                        (<t t-esc="po['role']"/>)
                                                    </span>
                                                </t>
                                            </div>
                                        </t>
                                    </td>

                                    <!-- Notes -->
                                    <td class="pti-notes">
                                        <t t-esc="slot['notes']"/>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                    </table>

                    <!-- Empty state -->
                    <t t-if="not data['slots']">
                        <p style="text-align: center; color: #999; margin-top: 40px;">
                            No interviews scheduled for this teacher in this cycle.
                        </p>
                    </t>
                </div>
            </t>
        </t>
    </template>

</odoo>
