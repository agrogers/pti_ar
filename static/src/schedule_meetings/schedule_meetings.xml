<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">

    <!-- ================================================================
         Unified Slot / Meeting Dialog
         ================================================================ -->
    <t t-name="pti_ar.SlotDialog">
        <div class="pti-sm-overlay" t-on-click.self="props.onClose">
            <div class="pti-sm-dialog pti-sm-dialog-wide">
                <div class="pti-sm-dialog-header">
                    <span class="pti-sm-dialog-title">Time Slot</span>
                    <button class="pti-sm-dialog-close" t-on-click="props.onClose">&#x2715;</button>
                </div>
                <div class="pti-sm-dialog-body">
                    <!-- Time &amp; Teacher -->
                    <div class="pti-sm-detail-row">
                        <span class="fa fa-clock-o pti-sm-detail-icon"/>
                        <div>
                            <div class="fw-semibold" t-esc="props.slotLabel"/>
                            <div class="text-muted small">Teacher: <strong t-esc="props.teacherName"/></div>
                        </div>
                    </div>

                    <!-- Global slot unavailable notice -->
                    <t t-if="isSlotUnavailable">
                        <div class="alert alert-warning mt-3 mb-0 d-flex align-items-center gap-2">
                            <span class="fa fa-ban"/>
                            <span>This time slot is <strong>unavailable</strong>. No meetings can be scheduled for this time.</span>
                        </div>
                    </t>

                    <!-- Slot Availability (only when no existing meeting and slot is not globally unavailable) -->
                    <t t-if="!isBooked and !isSlotUnavailable">
                        <div class="pti-sm-detail-section mt-3">
                            <label class="pti-sm-detail-label" for="pti-slot-status-select">Slot Availability</label>
                            <select id="pti-slot-status-select" class="form-select form-select-sm" t-on-change="onStatusChange">
                                <option value="available" t-att-selected="state.selectedStatus === 'available'">&#x2713; Available</option>
                                <option value="unavailable" t-att-selected="state.selectedStatus === 'unavailable'">&#x2717; Unavailable</option>
                            </select>
                        </div>
                    </t>

                    <!-- People section (hidden when set to unavailable on a free slot) -->
                    <t t-if="showPeopleSection">

                        <!-- Connected Students -->
                        <div class="pti-sm-detail-section mt-3">
                            <div class="pti-sm-detail-label d-flex align-items-center justify-content-between">
                                <span>Connected Students</span>
                                <button class="btn btn-sm btn-outline-primary" t-on-click="addConnectedStudent">
                                    <span class="fa fa-plus me-1"/>Add Student
                                </button>
                            </div>
                            <t t-if="state.connectedStudents.length">
                                <div class="pti-sm-detail-chips">
                                    <t t-foreach="state.connectedStudents" t-as="stu" t-key="stu.id">
                                        <span class="pti-sm-detail-chip pti-sm-chip-student">
                                            <span class="pti-sm-chip-initials" t-esc="getInitials(stu.name)"/>
                                            <span t-esc="stu.name"/>
                                            <button class="pti-sm-chip-remove" t-on-click="() => this.removeConnectedStudent(stu.id)"><span class="fa fa-trash"/></button>
                                        </span>
                                    </t>
                                </div>
                            </t>
                            <div class="text-muted small" t-if="!state.connectedStudents.length">No students added.</div>
                        </div>

                        <!-- Meeting Members -->
                        <div class="pti-sm-detail-section mt-3">
                            <div class="pti-sm-detail-label">Meeting Members</div>

                            <!-- Teachers -->
                            <div class="pti-sm-member-group mt-2">
                                <div class="d-flex align-items-center justify-content-between">
                                    <span class="badge bg-primary">Teachers</span>
                                    <!-- <span class="fw-semibold small"><span class="fa fa-graduation-cap me-1"/>Teachers</span> -->
                                    
                                    <button class="btn btn-sm btn-outline-primary" t-on-click="() => this.addMember('teacher')">
                                        <span class="fa fa-plus me-1"/>Add Teacher
                                    </button>
                                </div>
                                <t t-if="teacherMembers.length">
                                    <div class="pti-sm-detail-members mt-1">
                                        <t t-foreach="teacherMembers" t-as="mem" t-key="mem.partner_id">
                                            <div class="pti-sm-detail-member">
                                                <span class="pti-sm-chip-initials" t-esc="getInitials(mem.partner_name)"/>
                                                <span class="pti-sm-member-name" t-esc="mem.partner_name"/>
                                                <!-- <span class="badge bg-primary">Teacher</span> -->
                                                <button class="pti-sm-chip-remove" t-on-click="() => this.removeMember(mem.partner_id, 'teacher')"><span class="fa fa-trash"/></button>
                                            </div>
                                        </t>
                                    </div>
                                </t>
                            </div>

                            <!-- Parents -->
                            <div class="pti-sm-member-group mt-2">
                                <div class="d-flex align-items-center justify-content-between">
                                    <!-- <span class="fw-semibold small"><span class="fa fa-users me-1"/>Parents</span> -->
                                    <span class="badge bg-success">Parents</span>
                                    <button class="btn btn-sm btn-outline-success" t-on-click="() => this.addMember('parent')">
                                        <span class="fa fa-plus me-1"/>Add Parent
                                    </button>
                                </div>
                                <t t-if="parentMembers.length">
                                    <div class="pti-sm-detail-members mt-1">
                                        <t t-foreach="parentMembers" t-as="mem" t-key="mem.partner_id">
                                            <div class="pti-sm-detail-member">
                                                <span class="pti-sm-chip-initials" t-esc="getInitials(mem.partner_name)"/>
                                                <span class="pti-sm-member-name" t-esc="mem.partner_name"/>
                                                <!-- <span class="badge bg-success">Parent</span> -->
                                                <button class="pti-sm-chip-remove" t-on-click="() => this.removeMember(mem.partner_id, 'parent')"><span class="fa fa-trash"/></button>
                                            </div>
                                        </t>
                                    </div>
                                </t>
                            </div>

                            <!-- Observers -->
                            <div class="pti-sm-member-group mt-2">
                                <div class="d-flex align-items-center justify-content-between">
                                    <!-- <span class="fw-semibold small"><span class="fa fa-eye me-1"/>Observers</span> -->
                                    <span class="badge bg-info">Observers</span>
                                    <button class="btn btn-sm btn-outline-info" t-on-click="() => this.addMember('observer')">
                                        <span class="fa fa-plus me-1"/>Add Observer
                                    </button>
                                </div>
                                <t t-if="observerMembers.length">
                                    <div class="pti-sm-detail-members mt-1">
                                        <t t-foreach="observerMembers" t-as="mem" t-key="mem.partner_id">
                                            <div class="pti-sm-detail-member">
                                                <span class="pti-sm-chip-initials" t-esc="getInitials(mem.partner_name)"/>
                                                <span class="pti-sm-member-name" t-esc="mem.partner_name"/>
                                                <!-- <span class="badge bg-info">Observer</span> -->
                                                <button class="pti-sm-chip-remove" t-on-click="() => this.removeMember(mem.partner_id, 'observer')"><span class="fa fa-trash"/></button>
                                            </div>
                                        </t>
                                    </div>
                                </t>
                            </div>
                        </div>

                        <!-- Notes -->
                        <div class="pti-sm-detail-section mt-3">
                            <div class="pti-sm-detail-label">Notes</div>
                            <textarea
                                class="pti-sm-notes-area"
                                t-model="state.notes"
                                placeholder="Enter notes for this meeting…"
                                rows="3"
                            />
                        </div>
                    </t>
                </div>

                <!-- Footer -->
                <div class="pti-sm-dialog-footer">
                    <t t-if="isSlotUnavailable">
                        <button class="btn btn-secondary" t-on-click="props.onClose">Close</button>
                    </t>
                    <t t-elif="!state.confirmingDelete">
                        <t t-if="isBooked">
                            <button class="btn btn-danger me-auto" t-on-click="onDeleteClick">
                                <span class="fa fa-trash me-1"/>Delete Meeting
                            </button>
                        </t>
                        <button class="btn btn-secondary" t-on-click="props.onClose">
                            <t t-if="isBooked or hasPeople">Close</t>
                            <t t-else="">Cancel</t>
                        </button>
                        <button class="btn btn-primary ms-2" t-on-click="onSave">
                            <span class="fa fa-save me-1"/>
                            <t t-if="isBooked">Save</t>
                            <t t-elif="hasPeople">Book Meeting</t>
                            <t t-else="">Save</t>
                        </button>
                    </t>
                    <t t-else="">
                        <div class="pti-sm-delete-confirm">
                            <span class="text-danger fw-semibold">Are you sure? This will cancel the meeting and free the time slot.</span>
                            <div class="ms-auto d-flex gap-2">
                                <button class="btn btn-secondary btn-sm" t-on-click="onCancelDelete">Keep</button>
                                <button class="btn btn-danger btn-sm" t-on-click="onConfirmDelete">
                                    <span class="fa fa-trash me-1"/>Confirm Delete
                                </button>
                            </div>
                        </div>
                    </t>
                </div>
            </div>
        </div>
    </t>

    <!-- ================================================================
         Main Schedule Meetings component
         ================================================================ -->
    <t t-name="pti_ar.ScheduleMeetings">
        <div class="pti-schedule-meetings o_action o_form_view">

            <!-- Loading overlay -->
            <t t-if="state.loading">
                <div class="pti-sm-loading">
                    <span class="fa fa-spinner fa-spin fa-2x"/>
                </div>
            </t>

            <!-- Slot / Meeting Dialog -->
            <t t-if="state.slotDialog">
                <SlotDialog
                    slotLabel="state.slotDialog.slotLabel"
                    teacherName="state.slotDialog.teacherName"
                    teacherId="state.slotDialog.teacherId"
                    slotId="state.slotDialog.slotId"
                    status="state.slotDialog.status"
                    slotState="state.slotDialog.slotState"
                    meeting="state.slotDialog.meeting"
                    onSaveMeeting.bind="saveMeeting"
                    onSetUnavailable.bind="setSlotUnavailable"
                    onSetAvailable.bind="setSlotAvailable"
                    onDeleteMeeting.bind="deleteMeeting"
                    onClose.bind="closeSlotDialog"
                />
            </t>

            <!-- ============================================================
                 Page header
                 ============================================================ -->
            <div class="pti-sm-page-header">
                <h2>Schedule Meetings</h2>
            </div>

            <!-- ============================================================
                 Parent Selection Card
                 ============================================================ -->
            <div class="pti-sm-card">
                <div class="pti-sm-card-header">
                    <div class="d-flex align-items-center gap-3">
                        <h5 class="mb-0">Select</h5>
                        <div class="pti-sm-mode-selector">
                            <label class="pti-sm-mode-option" t-att-class="{ active: state.mode === 'parent' }">
                                <input type="radio" name="pti_mode" value="parent"
                                       t-att-checked="state.mode === 'parent'"
                                       t-on-change="() => this.setMode('parent')"/>
                                <span>Parent</span>
                            </label>
                            <label class="pti-sm-mode-option" t-att-class="{ active: state.mode === 'teacher' }">
                                <input type="radio" name="pti_mode" value="teacher"
                                       t-att-checked="state.mode === 'teacher'"
                                       t-on-change="() => this.setMode('teacher')"/>
                                <span>Teacher</span>
                            </label>
                        </div>
                    </div>
                </div>
                <div class="pti-sm-card-body">
                    <div class="pti-sm-parent-row">
                        <div class="pti-sm-parent-select-wrap">
                            <SearchDropdown
                                items="mainDropdownItems"
                                selectedId="mainDropdownSelectedId"
                                placeholder="mainDropdownPlaceholder"
                                noMatchText="mainDropdownNoMatch"
                                onSelect.bind="onMainDropdownSelect"
                                onClear.bind="onMainDropdownClear"
                                onReady.bind="onMainDropdownReady"
                            />
                        </div>
                        <!-- Meeting options (right column, parent mode only) -->
                        <div class="pti-sm-checkboxes" t-att-class="state.mode !== 'parent' ? 'd-none' : ''">
                            <div class="form-check form-switch">
                                <input
                                    type="checkbox"
                                    class="form-check-input"
                                    id="pti_include_students"
                                    t-att-checked="state.includeStudents"
                                    t-on-change="onIncludeStudentsChange"
                                />
                                <label class="form-check-label" for="pti_include_students">
                                    Include Students in Meeting
                                </label>
                            </div>
                            <div class="form-check form-switch mt-2">
                                <input
                                    type="checkbox"
                                    class="form-check-input"
                                    id="pti_include_spouse"
                                    t-att-checked="state.includeSpouse"
                                    t-on-change="onIncludeSpouseChange"
                                />
                                <label class="form-check-label" for="pti_include_spouse">
                                    Include Spouse in Meeting
                                </label>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ============================================================
                 Students and Teachers Selection Card (Parent Mode)
                 ============================================================ -->
            <t t-if="state.mode === 'parent' and state.parentData">
                <div class="pti-sm-card mt-3">
                    <div class="pti-sm-card-header">
                        <h5>Students &amp; Teachers</h5>
                        <p class="text-muted small mb-0">Select which teachers to schedule for each student</p>
                    </div>
                    <div class="pti-sm-card-body">
                        <t t-if="!state.parentData.students.length">
                            <p class="text-muted">No students found for this parent.</p>
                        </t>
                        <t t-foreach="state.parentData.students" t-as="student" t-key="student.id">
                            <div class="pti-sm-student-row">
                                <!-- Avatar + name -->
                                <div class="pti-sm-student-info">
                                    <div class="pti-sm-avatar">
                                        <t t-if="student.image">
                                            <img t-att-src="'data:image/png;base64,' + student.image" alt="Student"/>
                                        </t>
                                        <t t-else="">
                                            <span t-esc="getInitials(student.name)"/>
                                        </t>
                                    </div>
                                    <div>
                                        <div class="fw-semibold" t-esc="student.name"/>
                                    </div>
                                </div>

                                <!-- Teacher checkboxes -->
                                <div class="pti-sm-teacher-checks">
                                    <t t-if="!student.teachers.length">
                                        <span class="text-muted small">No teachers found</span>
                                    </t>
                                    <t t-foreach="student.teachers" t-as="teacher" t-key="teacher.id">
                                        <div
                                            class="pti-sm-teacher-check-item"
                                            t-att-class="isStudentTeacherBooked(student.id, teacher.id) ? 'pti-sm-teacher-booked' : ''"
                                        >
                                            <input
                                                type="checkbox"
                                                class="form-check-input me-2"
                                                t-att-id="'cb_' + student.id + '_' + teacher.id"
                                                t-att-checked="isTeacherSelected(student.id, teacher.id)"
                                                t-on-change="() => this.toggleTeacher(student.id, teacher.id)"
                                            />
                                            <label
                                                class="form-check-label"
                                                t-att-for="'cb_' + student.id + '_' + teacher.id"
                                            >
                                                <span t-esc="teacher.name"/>
                                                <span class="text-muted ms-1">(<t t-esc="teacher.subject"/>)</span>
                                                <t t-if="teacher.is_assistant">
                                                    <span class="badge bg-secondary ms-1">Asst</span>
                                                </t>
                                            </label>
                                        </div>
                                    </t>
                                </div>
                            </div>
                        </t>
                    </div>
                </div>
            </t>

            <!-- ============================================================
                 Students Selection Card (Teacher Mode)
                 ============================================================ -->
            <t t-if="state.mode === 'teacher' and state.teacherData">
                <div class="pti-sm-card mt-3">
                    <div class="pti-sm-card-header d-flex align-items-center gap-3 flex-wrap">
                        <h5 class="mb-0">Students</h5>
                        <div class="pti-sm-mode-selector">
                            <label class="pti-sm-mode-option" t-att-class="{ active: state.teacherStudentMode === 'all' }">
                                <input type="radio" name="pti_student_mode" value="all"
                                       t-att-checked="state.teacherStudentMode === 'all'"
                                       t-on-change="() => this.setTeacherStudentMode('all')"/>
                                <span>All Students</span>
                            </label>
                            <label class="pti-sm-mode-option" t-att-class="{ active: state.teacherStudentMode === 'single' }">
                                <input type="radio" name="pti_student_mode" value="single"
                                       t-att-checked="state.teacherStudentMode === 'single'"
                                       t-on-change="() => this.setTeacherStudentMode('single')"/>
                                <span>Single Student</span>
                            </label>
                        </div>
                        <t t-if="state.teacherStudentMode === 'single'">
                            <div class="pti-sm-student-select-wrap">
                                <SearchDropdown
                                    items="studentDropdownItems"
                                    selectedId="state.selectedSingleStudentId"
                                    placeholder="'Search student\u2026'"
                                    noMatchText="'No matching students'"
                                    onSelect.bind="onStudentDropdownSelect"
                                    onClear.bind="onStudentDropdownClear"
                                    onReady.bind="onStudentDropdownReady"
                                />
                            </div>
                        </t>
                    </div>
                </div>
            </t>

            <!-- No selection placeholder -->
            <t t-if="!state.parentData and !state.teacherData and !state.loading">
                <div class="pti-sm-card mt-3">
                    <div class="pti-sm-card-body text-center text-muted py-5">
                        <t t-if="state.mode === 'teacher'">Please select a teacher to begin scheduling interviews.</t>
                        <t t-else="">Please select a parent to begin scheduling interviews.</t>
                    </div>
                </div>
            </t>

            <!-- ============================================================
                 Time Slots Grid
                 ============================================================ -->
            <t t-set="teacherCols" t-value="getTeacherColumns()"/>
            <t t-if="state.slotData and teacherCols.length">
                <div class="pti-sm-card pti-sm-slots-card mt-3">
                    <div class="pti-sm-card-header">
                        <h5>Time Slots</h5>
                        <!-- Legend -->
                        <div class="pti-sm-legend">
                            <span class="pti-sm-legend-item pti-sm-slot-available">Available</span>
                            <span class="pti-sm-legend-item pti-sm-slot-booked-this">Your Bookings</span>
                            <span class="pti-sm-legend-item pti-sm-slot-booked-other">Other Bookings</span>
                        </div>
                    </div>
                    <div class="pti-sm-card-body p-0">
                        <div class="pti-sm-grid-outer">
                            <!-- Sticky header row -->
                            <div class="pti-sm-grid-header">
                                <!-- Time label column -->
                                <div class="pti-sm-col-time-header">Time</div>
                                <!-- Teacher columns -->
                                <t t-foreach="teacherCols" t-as="col" t-key="col.teacherId">
                                    <div class="pti-sm-col-teacher-header">
                                        <div class="d-flex align-items-center gap-2 fw-semibold">
                                            <span class="pti-sm-teacher-avatar">
                                                <t t-if="col.teacherImage">
                                                    <img t-att-src="'data:image/png;base64,' + col.teacherImage" t-att-alt="col.teacherName"/>
                                                </t>
                                                <t t-else="">
                                                    <span t-esc="getInitials(col.teacherName)"/>
                                                </t>
                                            </span>
                                            <span t-esc="col.teacherName"/>
                                        </div>
                                        <div class="pti-sm-col-students">
                                            <t t-foreach="col.students" t-as="st" t-key="st.studentId">
                                                <span class="pti-sm-col-student-tag">
                                                    <t t-esc="st.studentName"/>
                                                    <t t-if="st.subject"> (<t t-esc="st.subject"/>)</t>
                                                </span>
                                            </t>
                                        </div>
                                    </div>
                                </t>
                            </div>

                            <!-- Scrollable body -->
                            <div class="pti-sm-grid-body">
                                <t t-foreach="state.slotData.time_slots" t-as="slot" t-key="slot.id">
                                    <div class="pti-sm-grid-row"
                                         t-att-class="slot_index > 0 and state.slotData.time_slots[slot_index - 1].date_display !== slot.date_display ? 'pti-sm-day-break' : ''"
                                    >
                                        <!-- Time label -->
                                        <div class="pti-sm-col-time">
                                            <span class="pti-sm-time-date" t-esc="slot.date_display"/>
                                            <span class="pti-sm-time-range">
                                                <t t-esc="slot.start_display"/>
                                            </span>
                                        </div>

                                        <!-- Teacher cells -->
                                        <t t-foreach="teacherCols" t-as="col" t-key="col.teacherId">
                                            <t t-set="slotInfo" t-value="getSlotInfo(col.teacherId, slot.id)"/>
                                            <div
                                                class="pti-sm-slot-cell"
                                                t-att-class="
                                                    (isConflictSlot(slot.id) and (slotInfo.status === 'booked_this') ? ' pti-sm-slot-conflict' : '') +
                                                    ' ' +
                                                    (slotInfo.status === 'slot_unavailable' ? 'pti-sm-slot-unavailable' :
                                                    slotInfo.status === 'available'      ? 'pti-sm-slot-available' :
                                                    slotInfo.status === 'booked_this'    ? 'pti-sm-slot-booked-this' :
                                                    slotInfo.status === 'booked_other'   ? 'pti-sm-slot-booked-other' :
                                                    slotInfo.status === 'unavailable'    ? 'pti-sm-slot-unavailable' :
                                                    'pti-sm-slot-booked-other')
                                                "
                                            >
                                                <!-- SLOT UNAVAILABLE (global — applies to all teachers) -->
                                                <t t-if="slotInfo.status === 'slot_unavailable'">
                                                    <div class="pti-sm-slot-content">
                                                        <span class="pti-sm-unavailable-label">
                                                            <span class="fa fa-ban me-1"/>Unavailable
                                                        </span>
                                                        <div class="pti-sm-slot-icons">
                                                            <button
                                                                class="pti-sm-icon-btn text-muted"
                                                                title="Slot info"
                                                                t-on-click="() => this.openSlotDialog(slotInfo, col, slot)"
                                                            >
                                                                <span class="fa fa-info-circle"/>
                                                            </button>
                                                        </div>
                                                    </div>
                                                </t>

                                                 <!-- AVAILABLE or BOOKED (this parent) — show toggle avatars -->
                                                <t t-if="slotInfo.status === 'available' or slotInfo.status === 'booked_this'">
                                                    <div class="pti-sm-slot-content">
                                                        <div class="pti-sm-toggle-avatars">
                                                            <!-- Teacher mode + booked: show connected partners from the meeting itself
                                                                 so bookings for other students are always visible regardless of single-student filter -->
                                                            <t t-if="state.mode === 'teacher' and slotInfo.status === 'booked_this' and slotInfo.meeting">
                                                                <t t-foreach="slotInfo.meeting.connected_partners" t-as="cp" t-key="cp.id">
                                                                    <div class="pti-sm-toggle-wrap">
                                                                        <span class="pti-sm-toggle-btn pti-sm-toggle-booked-only pti-sm-toggle-static" t-att-title="cp.name">
                                                                            <t t-if="cp.image">
                                                                                <img class="pti-sm-toggle-img" t-att-src="'data:image/png;base64,' + cp.image" t-att-alt="cp.name"/>
                                                                            </t>
                                                                            <t t-else="">
                                                                                <span class="pti-sm-toggle-initials" t-esc="getInitials(cp.name)"/>
                                                                            </t>
                                                                        </span>
                                                                        <span class="pti-sm-toggle-name" t-esc="cp.name"/>
                                                                    </div>
                                                                </t>
                                                            </t>
                                                            <!-- All other cases: iterate effective students for toggle buttons -->
                                                            <t t-else="">
                                                            <t t-foreach="getEffectiveStudents()" t-as="st" t-key="st.id">
                                                                <t t-set="isConnected" t-value="slotInfo.meeting and slotInfo.meeting.connected_partner_ids.includes(st.id)"/>
                                                                <t t-set="isSelectedHere" t-value="(state.selectedTeachers[st.id] || []).includes(col.teacherId)"/>
                                                                <t t-set="showStudent" t-value="isConnected or isSelectedHere"/>
                                                                <t t-if="showStudent">
                                                                    <div class="pti-sm-toggle-wrap">
                                                                        <!-- Parent mode: Booked + selected: full active highlight -->
                                                                        <t t-if="isConnected and isSelectedHere">
                                                                            <span class="pti-sm-toggle-btn pti-sm-toggle-active pti-sm-toggle-static" t-att-title="st.name">
                                                                                <t t-if="st.image">
                                                                                    <img class="pti-sm-toggle-img" t-att-src="'data:image/png;base64,' + st.image" t-att-alt="st.name"/>
                                                                                </t>
                                                                                <t t-else="">
                                                                                    <span class="pti-sm-toggle-initials" t-esc="getInitials(st.name)"/>
                                                                                </t>
                                                                            </span>
                                                                        </t>
                                                                        <!-- Booked but NOT selected: muted booked indicator -->
                                                                        <t t-elif="isConnected">
                                                                            <span class="pti-sm-toggle-btn pti-sm-toggle-booked-only pti-sm-toggle-static" t-att-title="st.name">
                                                                                <t t-if="st.image">
                                                                                    <img class="pti-sm-toggle-img" t-att-src="'data:image/png;base64,' + st.image" t-att-alt="st.name"/>
                                                                                </t>
                                                                                <t t-else="">
                                                                                    <span class="pti-sm-toggle-initials" t-esc="getInitials(st.name)"/>
                                                                                </t>
                                                                            </span>
                                                                        </t>
                                                                        <!-- Selected but NOT booked: clickable green button (faded if already booked elsewhere) -->
                                                                        <t t-else="">
                                                                            <button
                                                                                class="pti-sm-toggle-btn"
                                                                                t-att-class="isStudentTeacherBooked(st.id, col.teacherId) ? 'pti-sm-toggle-faded' : ''"
                                                                                t-att-title="st.name"
                                                                                t-on-click="() => this.toggleStudent(st.id, col.teacherId, slot.id)"
                                                                            >
                                                                                <t t-if="st.image">
                                                                                    <img class="pti-sm-toggle-img" t-att-src="'data:image/png;base64,' + st.image" t-att-alt="st.name"/>
                                                                                </t>
                                                                                <t t-else="">
                                                                                    <span class="pti-sm-toggle-initials" t-esc="getInitials(st.name)"/>
                                                                                </t>
                                                                                <span class="pti-sm-toggle-plus">+</span>
                                                                            </button>
                                                                        </t>
                                                                        <span class="pti-sm-toggle-name" t-esc="st.name"/>
                                                                    </div>
                                                                </t>
                                                            </t>
                                                            </t>
                                                        </div>
                                                        <!-- Detail icons (always shown for available and booked_this) -->
                                                        <div class="pti-sm-slot-icons">
                                                            <t t-if="slotInfo.status === 'booked_this'">
                                                                <span class="pti-sm-icon-badge text-primary" title="Teachers in meeting">
                                                                    <span class="fa fa-graduation-cap"/>
                                                                    <span t-esc="slotInfo.meeting.teachers_count + slotInfo.meeting.observers_count"/>
                                                                </span>
                                                                <span class="pti-sm-icon-badge text-primary" title="Parents/students">
                                                                    <span class="fa fa-users"/>
                                                                    <span t-esc="slotInfo.meeting.parents_students_count"/>
                                                                </span>
                                                            </t>
                                                            <button
                                                                class="pti-sm-icon-btn text-primary"
                                                                title="Slot info"
                                                                t-on-click="() => this.openSlotDialog(slotInfo, col, slot)"
                                                            >
                                                                <span class="fa fa-info-circle"/>
                                                            </button>
                                                        </div>
                                                    </div>
                                                </t>

                                                <!-- BOOKED (other parent) -->
                                                <t t-if="slotInfo.status === 'booked_other'">
                                                    <div class="pti-sm-slot-content">
                                                        <div class="pti-sm-toggle-avatars">
                                                            <t t-foreach="slotInfo.meeting.connected_partners" t-as="cp" t-key="cp.id">
                                                                <div class="pti-sm-toggle-wrap">
                                                                    <span class="pti-sm-toggle-btn pti-sm-toggle-active pti-sm-toggle-static pti-sm-toggle-other" t-att-title="cp.name">
                                                                        <t t-if="cp.image">
                                                                            <img class="pti-sm-toggle-img" t-att-src="'data:image/png;base64,' + cp.image" t-att-alt="cp.name"/>
                                                                        </t>
                                                                        <t t-else="">
                                                                            <span class="pti-sm-toggle-initials" t-esc="getInitials(cp.name)"/>
                                                                        </t>
                                                                    </span>
                                                                    <span class="pti-sm-toggle-name" t-esc="cp.name"/>
                                                                </div>
                                                            </t>
                                                        </div>
                                                        <div class="pti-sm-slot-icons">
                                                            <span class="pti-sm-icon-badge text-muted" title="Teachers in meeting">
                                                                <span class="fa fa-graduation-cap"/>
                                                                <span t-esc="slotInfo.meeting.teachers_count + slotInfo.meeting.observers_count"/>
                                                            </span>
                                                            <span class="pti-sm-icon-badge text-muted" title="Parents/students">
                                                                <span class="fa fa-users"/>
                                                                <span t-esc="slotInfo.meeting.parents_students_count"/>
                                                            </span>
                                                            <button
                                                                class="pti-sm-icon-btn text-muted"
                                                                title="Meeting details"
                                                                t-on-click="() => this.openSlotDialog(slotInfo, col, slot)"
                                                            >
                                                                <span class="fa fa-info-circle"/>
                                                            </button>
                                                        </div>
                                                    </div>
                                                </t>

                                                <!-- UNAVAILABLE slot -->
                                                <t t-if="slotInfo.status === 'unavailable'">
                                                    <div class="pti-sm-slot-content">
                                                        <span class="pti-sm-unavailable-label">
                                                            <span class="fa fa-ban me-1"/>Unavailable
                                                        </span>
                                                        <div class="pti-sm-slot-icons">
                                                            <button
                                                                class="pti-sm-icon-btn text-primary"
                                                                title="Slot options"
                                                                t-on-click="() => this.openSlotDialog(slotInfo, col, slot)"
                                                            >
                                                                <span class="fa fa-info-circle"/>
                                                            </button>
                                                        </div>
                                                    </div>
                                                </t>
                                            </div>
                                        </t>
                                    </div>
                                </t>
                            </div>
                        </div>
                    </div>
                </div>
            </t>

        </div>
    </t>

</templates>
