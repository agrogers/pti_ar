<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Portrait A4 Paper Format -->
    <record id="paperformat_parent_schedule" model="report.paperformat">
        <field name="name">Parent Schedule (Portrait A4)</field>
        <field name="default" eval="False"/>
        <field name="format">A4</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">10</field>
        <field name="margin_bottom">10</field>
        <field name="margin_left">10</field>
        <field name="margin_right">10</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">0</field>
        <field name="dpi">90</field>
    </record>

    <!-- Report Action (appears in Print menu of parent summary list) -->
    <record id="action_report_parent_schedule" model="ir.actions.report">
        <field name="name">Parent Interview Schedule</field>
        <field name="model">pti.parent.meeting.summary</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">pti_ar.parent_schedule_report</field>
        <field name="report_file">pti_ar.parent_schedule_report</field>
        <field name="binding_model_id" ref="model_pti_parent_meeting_summary"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="pti_ar.paperformat_parent_schedule"/>
    </record>

    <!-- QWeb Report Template -->
    <template id="parent_schedule_report">
        <t t-call="web.html_container">
            <t t-foreach="report_data" t-as="data">
                <div class="article" t-attf-style="page-break-after: {{ 'always' if not data_last else 'auto' }};">
                    <style>
                        .pti-header {
                            display: flex;
                            align-items: center;
                            margin-bottom: 16px;
                            padding-bottom: 12px;
                            border-bottom: 2px solid #333;
                        }
                        .pti-photo {
                            width: 72px;
                            height: 72px;
                            border-radius: 50%;
                            object-fit: cover;
                            margin-right: 16px;
                            border: 2px solid #ccc;
                        }
                        .pti-initials-lg {
                            width: 72px;
                            height: 72px;
                            border-radius: 50%;
                            background-color: #875a7b;
                            color: #fff;
                            display: flex;
                            align-items: center;
                            justify-content: center;
                            font-size: 28px;
                            font-weight: bold;
                            margin-right: 16px;
                            flex-shrink: 0;
                        }
                        .pti-parent-name {
                            font-size: 22px;
                            font-weight: bold;
                            margin: 0;
                        }
                        .pti-cycle-name {
                            font-size: 13px;
                            color: #666;
                            margin: 4px 0 0 0;
                        }
                        .pti-students-section {
                            margin-bottom: 16px;
                        }
                        .pti-students-section h3 {
                            font-size: 14px;
                            font-weight: bold;
                            margin: 0 0 8px 0;
                            color: #333;
                        }
                        .pti-student-header {
                            display: flex;
                            align-items: center;
                            margin-bottom: 6px;
                        }
                        .pti-student-header:last-child {
                            margin-bottom: 0;
                        }
                        .pti-student-photo-md {
                            width: 40px;
                            height: 40px;
                            border-radius: 50%;
                            object-fit: cover;
                            margin-right: 10px;
                            border: 2px solid #ccc;
                        }
                        .pti-initials-md {
                            width: 40px;
                            height: 40px;
                            border-radius: 50%;
                            background-color: #00a09d;
                            color: #fff;
                            display: flex;
                            align-items: center;
                            justify-content: center;
                            font-size: 16px;
                            font-weight: bold;
                            margin-right: 10px;
                            flex-shrink: 0;
                        }
                        .pti-student-name {
                            font-size: 14px;
                        }
                        .pti-table {
                            width: 100%;
                            border-collapse: collapse;
                            font-size: 12px;
                        }
                        .pti-table th {
                            background-color: #f5f5f5;
                            border: 1px solid #ddd;
                            padding: 6px 8px;
                            text-align: left;
                            font-weight: bold;
                        }
                        .pti-table td {
                            border: 1px solid #ddd;
                            padding: 5px 8px;
                            vertical-align: top;
                        }
                        .pti-student {
                            display: flex;
                            align-items: center;
                            margin-bottom: 3px;
                        }
                        .pti-student:last-child {
                            margin-bottom: 0;
                        }
                        .pti-student-photo {
                            width: 24px;
                            height: 24px;
                            border-radius: 50%;
                            object-fit: cover;
                            margin-right: 6px;
                            flex-shrink: 0;
                        }
                        .pti-initials-sm {
                            width: 24px;
                            height: 24px;
                            border-radius: 50%;
                            background-color: #00a09d;
                            color: #fff;
                            display: inline-flex;
                            align-items: center;
                            justify-content: center;
                            font-size: 10px;
                            font-weight: bold;
                            margin-right: 6px;
                            flex-shrink: 0;
                        }
                        .pti-teacher {
                            display: flex;
                            align-items: center;
                            margin-bottom: 3px;
                        }
                        .pti-teacher:last-child {
                            margin-bottom: 0;
                        }
                    </style>

                    <!-- Parent Header with photo/initials -->
                    <div class="pti-header">
                        <t t-if="data['parent'].image_128">
                            <img class="pti-photo"
                                 t-att-src="image_data_uri(data['parent'].image_128)"/>
                        </t>
                        <t t-else="">
                            <div class="pti-initials-lg">
                                <t t-esc="data['parent_initials']"/>
                            </div>
                        </t>
                        <div>
                            <p class="pti-parent-name" t-esc="data['parent'].name"/>
                            <p class="pti-cycle-name" t-esc="data['cycle'].display_name"/>
                        </div>
                    </div>

                    <!-- Students Section -->
                    <t t-if="data['all_students']">
                        <div class="pti-students-section">
                            <h3>Student(s)</h3>
                            <t t-foreach="data['all_students']" t-as="student">
                                <div class="pti-student-header">
                                    <t t-if="student['partner'].image_128">
                                        <img class="pti-student-photo-md"
                                             t-att-src="image_data_uri(student['partner'].image_128)"/>
                                    </t>
                                    <t t-else="">
                                        <div class="pti-initials-md">
                                            <t t-esc="student['initials']"/>
                                        </div>
                                    </t>
                                    <span class="pti-student-name" t-esc="student['partner'].name"/>
                                </div>
                            </t>
                        </div>
                    </t>

                    <!-- Schedule Table -->
                    <table class="pti-table">
                        <thead>
                            <tr>
                                <th scope="col" style="width: 30%;">Date/Time</th>
                                <th scope="col" style="width: 35%;">Teacher(s)</th>
                                <th scope="col" style="width: 35%;">Student(s)</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="data['meetings']" t-as="meeting">
                                <tr>
                                    <!-- Date/Time -->
                                    <td>
                                        <t t-esc="meeting['date_time_display']"/>
                                    </td>

                                    <!-- Teachers -->
                                    <td>
                                        <t t-foreach="meeting['teachers']" t-as="teacher">
                                            <div class="pti-teacher">
                                                <t t-if="teacher['partner'].image_128">
                                                    <img class="pti-student-photo"
                                                         t-att-src="image_data_uri(teacher['partner'].image_128)"/>
                                                </t>
                                                <t t-else="">
                                                    <span class="pti-initials-sm">
                                                        <t t-esc="teacher['initials']"/>
                                                    </span>
                                                </t>
                                                <span t-esc="teacher['partner'].name"/>
                                            </div>
                                        </t>
                                    </td>

                                    <!-- Students -->
                                    <td>
                                        <t t-foreach="meeting['students']" t-as="student">
                                            <div class="pti-student">
                                                <t t-if="student['partner'].image_128">
                                                    <img class="pti-student-photo"
                                                         t-att-src="image_data_uri(student['partner'].image_128)"/>
                                                </t>
                                                <t t-else="">
                                                    <span class="pti-initials-sm">
                                                        <t t-esc="student['initials']"/>
                                                    </span>
                                                </t>
                                                <span t-esc="student['partner'].name"/>
                                            </div>
                                        </t>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                    </table>

                    <!-- Empty state -->
                    <t t-if="not data['meetings']">
                        <p style="text-align: center; color: #999; margin-top: 40px;">
                            No interviews scheduled for this parent in this cycle.
                        </p>
                    </t>
                </div>
            </t>
        </t>
    </template>

</odoo>
