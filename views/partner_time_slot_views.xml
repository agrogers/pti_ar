<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List View -->
    <record id="pti_partner_time_slot_view_list" model="ir.ui.view">
        <field name="name">pti.partner.time.slot.list</field>
        <field name="model">pti.partner.time.slot</field>
        <field name="arch" type="xml">
            <list>
                <field name="partner_id"/>
                <field name="time_slot_id"/>
                <field name="status"/>
                <field name="meeting_id" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="pti_partner_time_slot_view_form" model="ir.ui.view">
        <field name="name">pti.partner.time.slot.form</field>
        <field name="model">pti.partner.time.slot</field>
        <field name="arch" type="xml">
            <form string="Partner Time Slot">
                <header>
                    <field name="status" widget="statusbar"
                           statusbar_visible="available,booked,completed"/>
                </header>
                <sheet>
                    <group>
                        <group string="Booking">
                            <field name="partner_id"/>
                            <field name="time_slot_id"/>
                        </group>
                        <group string="Meeting">
                            <field name="meeting_id"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="pti_partner_time_slot_view_search" model="ir.ui.view">
        <field name="name">pti.partner.time.slot.search</field>
        <field name="model">pti.partner.time.slot</field>
        <field name="arch" type="xml">
            <search string="Partner Time Slots">
                <field name="partner_id"/>
                <field name="time_slot_id"/>
                <field name="meeting_id"/>
                <filter string="Available" name="available" domain="[('status', '=', 'available')]"/>
                <filter string="Booked" name="booked" domain="[('status', '=', 'booked')]"/>
                <filter string="Cancelled" name="cancelled" domain="[('status', '=', 'cancelled')]"/>
                <filter string="Completed" name="completed" domain="[('status', '=', 'completed')]"/>
                <group expand="0" string="Group By">
                    <filter string="Partner" name="group_partner" context="{'group_by': 'partner_id'}"/>
                    <filter string="Status" name="group_status" context="{'group_by': 'status'}"/>
                    <filter string="Meeting" name="group_meeting" context="{'group_by': 'meeting_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Window Action -->
    <record id="pti_partner_time_slot_action" model="ir.actions.act_window">
        <field name="name">Partner Time Slots</field>
        <field name="res_model">pti.partner.time.slot</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="pti_partner_time_slot_view_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No time slot bookings found.
            </p>
        </field>
    </record>

</odoo>
