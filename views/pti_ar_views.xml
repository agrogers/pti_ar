<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Tree View -->
    <record id="pti_ar_view_list" model="ir.ui.view">
        <field name="name">pti.ar.list</field>
        <field name="model">pti.ar</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="description" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="pti_ar_view_form" model="ir.ui.view">
        <field name="name">pti.ar.form</field>
        <field name="model">pti.ar</field>
        <field name="arch" type="xml">
            <form string="PTI AR">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                        </group>
                        <group>
                            <field name="active" invisible="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="pti_ar_view_search" model="ir.ui.view">
        <field name="name">pti.ar.search</field>
        <field name="model">pti.ar</field>
        <field name="arch" type="xml">
            <search string="PTI AR">
                <field name="name"/>
                <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="pti_ar_action" model="ir.actions.act_window">
        <field name="name">PTI AR</field>
        <field name="res_model">pti.ar</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="pti_ar_view_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first PTI AR record
            </p>
        </field>
    </record>

</odoo>
