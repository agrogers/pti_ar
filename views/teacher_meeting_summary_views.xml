<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List View -->
    <record id="pti_teacher_meeting_summary_view_list" model="ir.ui.view">
        <field name="name">pti.teacher.meeting.summary.list</field>
        <field name="model">pti.teacher.meeting.summary</field>
        <field name="arch" type="xml">
            <list create="false" edit="false" delete="false">
                <field name="teacher_id"/>
                <field name="meeting_cycle_id"/>
                <field name="meeting_count" sum="Total"/>
            </list>
        </field>
    </record>

    <!-- Search View -->
    <record id="pti_teacher_meeting_summary_view_search" model="ir.ui.view">
        <field name="name">pti.teacher.meeting.summary.search</field>
        <field name="model">pti.teacher.meeting.summary</field>
        <field name="arch" type="xml">
            <search string="Teacher Meeting Summary">
                <field name="teacher_id"/>
                <field name="meeting_cycle_id"/>
                <group expand="0" string="Group By">
                    <filter string="Teacher" name="group_teacher"
                            context="{'group_by': 'teacher_id'}"/>
                    <filter string="Meeting Cycle" name="group_cycle"
                            context="{'group_by': 'meeting_cycle_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Window Action -->
    <record id="pti_teacher_meeting_summary_action" model="ir.actions.act_window">
        <field name="name">Teacher Interview Summary</field>
        <field name="res_model">pti.teacher.meeting.summary</field>
        <field name="view_mode">list</field>
        <field name="search_view_id" ref="pti_teacher_meeting_summary_view_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No interviews scheduled yet.
            </p>
        </field>
    </record>

</odoo>
