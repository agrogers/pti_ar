<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List View -->
    <record id="pti_parent_meeting_summary_view_list" model="ir.ui.view">
        <field name="name">pti.parent.meeting.summary.list</field>
        <field name="model">pti.parent.meeting.summary</field>
        <field name="arch" type="xml">
            <list create="false" edit="false" delete="false">
                <field name="parent_id"/>
                <field name="meeting_cycle_id"/>
                <button name="action_view_meetings" type="object"
                        icon="fa-list" title="View Meetings"/>
                <field name="meeting_count" sum="Total"/>
                <field name="last_meeting_write_date" optional="show"/>
            </list>
        </field>
    </record>

    <!-- Search View -->
    <record id="pti_parent_meeting_summary_view_search" model="ir.ui.view">
        <field name="name">pti.parent.meeting.summary.search</field>
        <field name="model">pti.parent.meeting.summary</field>
        <field name="arch" type="xml">
            <search string="Parent Meeting Summary">
                <field name="parent_id"/>
                <field name="meeting_cycle_id"/>
                <group expand="0" string="Group By">
                    <filter string="Parent" name="group_parent"
                            context="{'group_by': 'parent_id'}"/>
                    <filter string="Meeting Cycle" name="group_cycle"
                            context="{'group_by': 'meeting_cycle_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Window Action -->
    <record id="pti_parent_meeting_summary_action" model="ir.actions.act_window">
        <field name="name">Parent Interview Summary</field>
        <field name="res_model">pti.parent.meeting.summary</field>
        <field name="view_mode">list</field>
        <field name="search_view_id" ref="pti_parent_meeting_summary_view_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No interviews scheduled yet.
            </p>
        </field>
    </record>

</odoo>
